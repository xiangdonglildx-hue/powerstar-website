# Google Search Console API Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Path to Service Account JSON key file (downloaded from GCP Console)
# This file contains your private key for API authentication
# IMPORTANT: Never commit credentials.json to git!
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# =============================================================================
# GSC CONFIGURATION
# =============================================================================

# GSC Site URL (the property you added in Search Console)
# Use the exact URL from your Search Console property, including protocol
# For domain properties, use: sc-domain:powerstarapps.com
# For URL properties, use: https://powerstarapps.com
GSC_SITE_URL=https://powerstarapps.com

# =============================================================================
# DATA OUTPUT PATHS
# =============================================================================

# Path to main SEO metrics JSON file (relative to scripts directory)
DATA_OUTPUT_PATH=../data/seo-metrics.json

# Path to historical data directory for daily snapshots
HISTORY_OUTPUT_PATH=../data/history

# =============================================================================
# IMPORTANT NOTES
# =============================================================================

# 1. Copy this file to .env before running scripts:
#    cp .env.example .env
#
# 2. Download your Service Account JSON key from GCP Console:
#    - Go to: console.cloud.google.com > IAM & Admin > Service Accounts
#    - Click on your service account
#    - Go to "Keys" tab > "Add Key" > "Create new key" > JSON
#    - Save the downloaded file as credentials.json in this directory
#
# 3. Add the Service Account email to your GSC property:
#    - Go to: search.google.com/search-console
#    - Select your property
#    - Settings > Users and permissions > Add user
#    - Paste the client_email from credentials.json
#    - Permission: Full or Restricted (Restricted with "View" is sufficient)
#
# 4. NEVER commit these files to git:
#    - .env
#    - credentials.json
#    Both are already in .gitignore